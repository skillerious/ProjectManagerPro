{
  "name": "project-manager-pro",
  "version": "2.6.1",
  "description": "Professional Project Manager with VSCode-like interface",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "keygen": "electron keygen/main.js",
    "build-win": "electron-builder --win",
    "dist": "electron-builder",
    "run-dist": "npm run dist",
    "lint": "eslint main/**/*.js security-utils.js license-utils.js preload.js scripts/**/*.js tests/**/*.js",
    "test:safety": "node --test tests/security-utils.test.js tests/license-utils.test.js tests/license-manager.test.js tests/operation-queue.test.js tests/workspace-services.test.js tests/project-discovery-service.test.js tests/ipc-contract.test.js tests/update-manager.test.js tests/config-consistency.test.js tests/renderer-contract.test.js",
    "generate:key": "node scripts/generate-product-key.js",
    "build-keygen": "electron-builder --config keygen/builder.json"
  },
  "author": "Project Manager Pro",
  "license": "MIT",
  "devDependencies": {
    "electron": "^39.2.3",
    "electron-builder": "^24.6.4",
    "eslint": "^9.39.3"
  },
  "build": {
    "appId": "com.projectmanager.pro",
    "productName": "Project Manager Pro",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "assets/delete.png",
        "to": "assets/delete.png"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "skillerious",
        "repo": "ProjectManagerPro",
        "releaseType": "release"
      }
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.4.0",
    "chokidar": "^3.5.3",
    "diff": "^5.1.0",
    "electron-updater": "^6.3.9",
    "vis-network": "^9.1.6"
  },
  "optionalDependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  }
}
